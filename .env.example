# All variables are required (validated at startup). Copy to .env and fill every value.

NODE_ENV=development
DATABASE_URL=postgresql://memrider:memrider@localhost:5432/memrider?schema=public
PORT=3001
CORS_ORIGIN=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Local embeddings (EMBEDDING_DIMENSION must match Prisma vector column size)
EMBEDDING_MODEL_ID=Xenova/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384
EMBEDDING_QUANTIZED=true

# Amazon Bedrock
AWS_REGION=eu-central-1
# Foundation model ID is fine — EU/US inference profile is resolved from AWS_REGION at runtime.
BEDROCK_MODEL_ID=amazon.nova-lite-v1:0
AWS_BEARER_TOKEN_BEDROCK=your-bedrock-api-key-here
AWS_AUTH_SCHEME_PREFERENCE=httpBearerAuth

# Prompts (default: packages/journal/prompt-registry; override with absolute path if needed)
PROMPT_SET_NAME=memory-search
PROMPT_VERSION=v1
PROMPTS_DIR=../../packages/journal/prompt-registry

# Evaluation CLI (true or false)
RUN_LIVE_EVAL=false

# Auth — provisioned with Terraform. See infra/README.md
#   pnpm infra:bootstrap
#   cp infra/stacks/cognito/env/dev.tfvars.example infra/stacks/cognito/env/dev.tfvars
#   pnpm cognito:setup
AUTH_PROVIDER=cognito
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=

# Web (read from root .env via next.config.ts)
NEXT_PUBLIC_COGNITO_DOMAIN=
NEXT_PUBLIC_COGNITO_CLIENT_ID=
NEXT_PUBLIC_COGNITO_REGION=us-east-1
COGNITO_CLIENT_SECRET=

# Optional: defaults for pnpm cognito:user (do not commit real passwords)
# COGNITO_DEV_EMAIL=you@example.com
# COGNITO_DEV_PASSWORD=YourDevPassword1!
