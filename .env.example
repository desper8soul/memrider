# All variables are required (validated at startup). Copy to .env and fill every value.

NODE_ENV=development
DATABASE_URL=postgresql://memrider:memrider@localhost:5432/memrider?schema=public
PORT=3001
CORS_ORIGIN=http://localhost:3000

# Local embeddings (EMBEDDING_DIMENSION must match Prisma vector column size)
EMBEDDING_MODEL_ID=Xenova/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384
EMBEDDING_QUANTIZED=true

# Amazon Bedrock
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=amazon.nova-lite-v1:0
AWS_BEARER_TOKEN_BEDROCK=your-bedrock-api-key-here
AWS_AUTH_SCHEME_PREFERENCE=httpBearerAuth

# Prompts (default: packages/journal/prompt-registry; override with absolute path if needed)
PROMPT_SET_NAME=memory-search
PROMPT_VERSION=v1
PROMPTS_DIR=../../packages/journal/prompt-registry

# Evaluation CLI (true or false)
RUN_LIVE_EVAL=false
