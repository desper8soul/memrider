DATABASE_URL=postgresql://memrider:memrider@localhost:5432/memrider?schema=public
PORT=3001
CORS_ORIGIN=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001

# Amazon Bedrock (mock LLM used when region/token missing)
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=amazon.nova-lite-v1:0
AWS_BEARER_TOKEN_BEDROCK=your-bedrock-api-key-here
AWS_AUTH_SCHEME_PREFERENCE=httpBearerAuth

# Prompt versions (see apps/api/prompt-registry/memory-search/manifest.json)
PROMPT_MEMORY_SEARCH_VERSION=v1

# Evaluation CLI
RUN_LIVE_EVAL=0
