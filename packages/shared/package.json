{
  "name": "@memrider/shared",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "config": ["./dist/config/index.d.ts"],
      "config/api": ["./dist/config/api/index.d.ts"],
      "config/common": ["./dist/config/common/index.d.ts"],
      "logging": ["./dist/logging/index.d.ts"],
      "web-config": ["./dist/config/web/index.d.ts"],
      "schemas": ["./dist/schemas.d.ts"]
    }
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./schemas": {
      "types": "./dist/schemas.d.ts",
      "default": "./dist/schemas.js"
    },
    "./config": {
      "types": "./dist/config/index.d.ts",
      "default": "./dist/config/index.js"
    },
    "./config/api": {
      "types": "./dist/config/api/index.d.ts",
      "default": "./dist/config/api/index.js"
    },
    "./config/common": {
      "types": "./dist/config/common/index.d.ts",
      "default": "./dist/config/common/index.js"
    },
    "./logging": {
      "types": "./dist/logging/index.d.ts",
      "default": "./dist/logging/index.js"
    },
    "./web-config": {
      "types": "./dist/config/web/index.d.ts",
      "default": "./dist/config/web/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "ts-pattern": "catalog:",
    "zod": "catalog:"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "typescript": "catalog:"
  }
}
